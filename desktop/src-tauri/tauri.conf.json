{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Kakachi Desktop",
  "version": "0.1.0",
  "identifier": "com.kakachi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kakachi Desktop",
        "width": 1320,
        "height": 920,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
