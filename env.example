# Required: 32+ chars
KAKACHI_JWT_SECRET=replace-with-a-long-random-secret

# Optional API bind address
KAKACHI_API_BIND=127.0.0.1:8080

# Optional control-plane SQLite file path
KAKACHI_COORDINATION_DB=./.kakachi/control-plane.db

# Optional desktop local state directory
KAKACHI_DESKTOP_DATA_DIR=./.kakachi/desktop

# Optional logging
RUST_LOG=kakachi_api=info,tower_http=info,axum=info,kakachi_desktop=info
